<?xml version="1.0" encoding="UTF-8"?>
<profiles version="13">
<profile kind="CodeFormatterProfile" name="Kezul-Chop-Down" version="13">
    <!-- 기본 들여쓰기 설정 -->
    <setting id="org.eclipse.jdt.core.formatter.tabulation.char" value="space"/>
    <setting id="org.eclipse.jdt.core.formatter.tabulation.size" value="4"/>
    <setting id="org.eclipse.jdt.core.formatter.use_tabs_only_for_leading_indentations" value="false"/>
    
    <!-- 메서드 파라미터가 길 경우 Chop Down (개행) 설정 및 닫는 괄호 내림 -->
    <!-- 106 = WRAP_ALL_ELEMENTS | WRAP_NEXT_LINE (파라미터 모두 개행) -->
    <!-- 48 = WRAP_ALL_ELEMENTS (모든 요소를 새 줄에) -->
    <setting id="org.eclipse.jdt.core.formatter.alignment_for_parameters_in_method_declaration" value="48"/>
    <setting id="org.eclipse.jdt.core.formatter.alignment_for_arguments_in_method_invocation" value="48"/>
    <setting id="org.eclipse.jdt.core.formatter.insert_new_line_after_annotation_on_parameter" value="insert"/>
    
    <!-- 줄바꿈 유지 (사용자가 의도적으로 내린 줄바꿈을 합치지 않음) -->
    <setting id="org.eclipse.jdt.core.formatter.join_wrapped_lines" value="false"/>
    <setting id="org.eclipse.jdt.core.formatter.join_lines_in_comments" value="false"/>
</profile>
</profiles>
